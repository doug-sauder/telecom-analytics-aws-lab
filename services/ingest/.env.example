# Copy this file to .env and adjust values as needed.
# Do not commit .env to version control.

# Database connection (postgres container in Compose)
PGHOST=postgres
PGUSER=telecom
PGPASSWORD=telecom
PGDATABASE=telecom
PGPORT=5432

# Service
PORT=3000

# Kafka
BROKER_URL=redpanda:9092
TOPIC_NAME=pm.events
BATCH_SIZE=100
POLL_INTERVAL_MS=500
CONSUMER_GROUP_ID=telecom.analytics.ingest